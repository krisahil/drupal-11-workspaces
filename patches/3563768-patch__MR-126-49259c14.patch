+   *   - label: (string) The entity's label/title.
+   *   - entity_type_id: (string) The ID of the entity's type (e.g., "node")
+   *   - entity_type_label: (string) The label of the entity's type (e.g.,
+   *   "Content")
+   *   - has_bundles: (bool) Whether this entity type has bundles.
+   *   - bundles_general_label: (string) This is the label of the names of
+   *   bundles. E.g., for entity type node, this would be "Content type".
+   *   - bundle_label: (string) The entity type's bundle label.
+   */
+  protected function getEntityInfo(): array {
+    $entity_type_id = $this->entity->getEntityTypeId();
+    $bundle_info = $this->entityTypeBundleInfo->getBundleInfo($entity_type_id);
+    $bundle_key = $this->entity->bundle();
+
+    return [
+      'entity_id' => $this->entity->id(),
+      'label' => $this->entity->label() ?: '(No title)',
+      'entity_type_id' => $this->entity->getEntityTypeId(),
+      'entity_type_label' => $this->entity->getEntityType()->getLabel(),
+      'has_bundles' => count($bundle_info) > 1,
+      'bundles_general_label' => $this->entity->getEntityType()->getBundleLabel(),
+      'bundle_label' => $bundle_info[$bundle_key]['label'],
+    ];
+  }
+
 }
